# Test artifacts (exclude temporary test files and downloads)
tests/*/
.tmp
.tmp/*/

# Ignore JSON files (Delta logs, test data, etc.)
*.json

# Ignore CSV files
*.csv

# But DO keep integration test fixtures and dbt project files
!integration_tests/**/*.csv
!integration_tests/**/*.yml
!integration_tests/**/*.json

# Delta output and dbt artifacts produced by the integration tests (runtime)
integration_tests/warehouse/
integration_tests/target/
integration_tests/dbt_packages/
integration_tests/logs/
integration_tests/*.duckdb
integration_tests/*.duckdb.wal