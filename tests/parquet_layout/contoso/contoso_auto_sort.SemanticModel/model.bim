            "sourceColumn": "Quantity",
            "sourceLineageTag": "Quantity",
            "summarizeBy": "sum"
          },
          {
            "name": "Unit Price",
            "dataType": "decimal",
            "sourceColumn": "UnitPrice",
            "sourceLineageTag": "UnitPrice",
