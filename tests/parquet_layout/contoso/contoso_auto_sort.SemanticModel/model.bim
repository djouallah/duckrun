            "sourceColumn": "ExchangeRate",
            "sourceLineageTag": "ExchangeRate",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "Sales",
            "mode": "directLake",
            "source": {
              "type": "entity",
              "entityName": "sales_auto_sort",
              "expressionSource": "DirectLake",
              "schemaName": "tests"
            }
          }
        ],
        "measures": [
          {
            "name": "Sales Amount",
            "expression": "SUMX ( Sales, Sales[Quantity] * Sales[Net Price] )",
            "formatString": "#,0.00"
          },
          {
            "name": "Total Cost",
            "expression": "SUMX ( Sales, Sales[Quantity] * Sales[Unit Cost] )",
            "formatString": "#,0.00"
          },
          {
            "name": "Margin",
            "expression": "[Sales Amount] - [Total Cost]",
            "formatString": "#,0.00"
          },
          {
            "name": "Margin %",
            "expression": "DIVIDE ( [Margin], [Sales Amount] )",
            "formatString": "0.00%;-0.00%;0.00%"
          },
          {
            "name": "Total Quantity",
            "expression": "SUM ( Sales[Quantity] )",
            "formatString": "#,0"
          }
        ]
      },
