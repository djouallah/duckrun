{
  "compatibilityLevel": 1604,
  "model": {
    "culture": "en-US",
    "defaultPowerBIDataSourceVersion": "powerBI_V3",
    "annotations": [
      {
        "name": "PBI_ProTooling",
        "value": "[\"RemoteModeling\", \"DirectLakeOnOneLakeCreatedInDesktop\"]"
      }
    ],
    "expressions": [
      {
        "name": "DirectLake",
        "kind": "m",
        "description": "Direct Lake connection to OneLake \u2014 reads Delta tables directly, no SQL endpoint",
        "expression": [
          "let",
          "    Source = AzureStorage.DataLake(\"https://onelake.dfs.fabric.microsoft.com/11111111-1111-1111-1111-111111111111/22222222-2222-2222-2222-222222222222\", [HierarchicalNavigation=true])",
          "in",
          "    Source"
        ]
      }
    ],
