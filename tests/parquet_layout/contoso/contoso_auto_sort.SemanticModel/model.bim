          },
          {
            "name": "Unit Cost",
            "dataType": "decimal",
            "sourceColumn": "UnitCost",
            "sourceLineageTag": "UnitCost",
            "summarizeBy": "none",
            "formatString": "#,0.00"
          },
          {
            "name": "Currency Code",
