# ============================================================================
# 07_errors.slt -- failures must raise a clean exception, and a failed
# statement must never leave partial data or wedge the connection.
# ============================================================================

statement error
SELECT * FROM table_that_does_not_exist

statement error
SELECT * FROM missing_tbl_xyz
----
missing_tbl_xyz

statement error
SELEKT 1

statement error
SELECT 'unterminated

statement error
SELECT ((1 + 2)

statement error
INSERT INTO

statement error
CREATE TABLE

statement ok
CREATE TABLE err_t (i INTEGER, s VARCHAR)

statement error
INSERT INTO err_t VALUES (1)

statement error
INSERT INTO err_t VALUES (1, 'a', 2)

statement error
INSERT INTO err_t (i, nope) VALUES (1, 'a')

statement error
