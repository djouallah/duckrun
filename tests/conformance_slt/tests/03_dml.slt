# ============================================================================
# 03_dml.slt -- insert / update / delete lifecycle
# ============================================================================

statement ok
CREATE TABLE dml (id INTEGER, val VARCHAR, amt DOUBLE)

statement ok
INSERT INTO dml VALUES (1, 'a', 1.5), (2, 'b', 2.5), (3, 'c', NULL)

statement ok
INSERT INTO dml (id, val) VALUES (4, 'd')

statement ok
INSERT INTO dml (val, id) VALUES ('e', 5)

query ITR
SELECT id, val, amt FROM dml ORDER BY id
----
1
a
1.500
2
b
2.500
3
c
NULL
4
d
NULL
5
e
NULL

# insert-select from another table
statement ok
CREATE TABLE dml_src (id INTEGER, val VARCHAR)

statement ok
INSERT INTO dml_src SELECT range + 100, 'src_' || range FROM range(5)

statement ok
INSERT INTO dml (id, val) SELECT id, val FROM dml_src

query I
SELECT count(*) FROM dml
----
10

# self-referencing insert: source reads the target table (non-blind append)
statement ok
INSERT INTO dml (id, val) SELECT max(id) + 1, 'auto' FROM dml

query I
SELECT max(id) FROM dml
----
105

# self-referencing doubling
statement ok
CREATE TABLE dbl (v INTEGER)

statement ok
INSERT INTO dbl VALUES (1), (2)

statement ok
INSERT INTO dbl SELECT v + 10 FROM dbl

query I rowsort
SELECT v FROM dbl
----
1
11
12
2

# ---------------------------------------------------------------- update

statement ok
UPDATE dml SET amt = 0.0 WHERE amt IS NULL

query I
SELECT count(*) FROM dml WHERE amt = 0.0
----
9

statement ok
UPDATE dml SET amt = amt + 1 WHERE id <= 2

query R
SELECT sum(amt) FROM dml WHERE id <= 2
----
6.000

statement ok
UPDATE dml SET val = upper(val) WHERE id IN (SELECT id FROM dml_src)

query I
SELECT count(*) FROM dml WHERE val LIKE 'SRC%'
----
5

statement ok
UPDATE dml SET amt = NULL WHERE id = 105

query I
SELECT count(*) FROM dml WHERE amt IS NULL
----
1

# multi-column update with expressions referencing old values
statement ok
UPDATE dml SET id = id + 1000, val = val || '_moved' WHERE id = 105

query IT
SELECT id, val FROM dml WHERE id > 1000
----
1105
auto_moved

# update that touches zero rows
statement ok
UPDATE dml SET val = 'x' WHERE id = -999

query I
SELECT count(*) FROM dml WHERE val = 'x'
----
0

# ---------------------------------------------------------------- delete

statement ok
DELETE FROM dml WHERE id > 1000

query I
SELECT count(*) FROM dml
----
10

statement ok
DELETE FROM dml WHERE id IN (SELECT max(id) FROM dml)

query II
SELECT count(*), max(id) FROM dml
----
9
103

statement ok
DELETE FROM dml WHERE id > 100

query II
SELECT count(*), max(id) FROM dml
----
6
100

# delete with an always-false predicate
statement ok
DELETE FROM dml WHERE 1 = 0

query I
SELECT count(*) FROM dml
----
6

# delete everything, then resurrect the table
statement ok
DELETE FROM dml

query I
SELECT count(*) FROM dml
----
0

statement ok
INSERT INTO dml VALUES (1, 'reborn', 3.25)

query ITR
SELECT id, val, amt FROM dml
----
1
reborn
3.250

# ---------------------------------------------------------------- optional DML surface

statement maybe
CREATE TABLE t_pk (id INTEGER PRIMARY KEY, v VARCHAR)

statement maybe
BEGIN TRANSACTION

statement maybe
ROLLBACK

statement maybe
TRUNCATE dml_src

statement maybe
MERGE INTO dml USING (SELECT 1 AS id, 'merged' AS val) s ON dml.id = s.id WHEN MATCHED THEN UPDATE SET val = s.val

# ---------------------------------------------------------------- one commit per row: log pressure

statement ok
CREATE TABLE batch (i INTEGER, tag VARCHAR)

loop i 0 100
statement ok
INSERT INTO batch VALUES (${i}, 'commit_${i}')
endloop

query II
SELECT count(*), sum(i) FROM batch
----
100
4950

query T
SELECT tag FROM batch WHERE i = 73
----
commit_73

statement ok
DELETE FROM batch WHERE i % 2 = 1

query II
SELECT count(*), sum(i) FROM batch
----
50
2450

statement ok
UPDATE batch SET i = i + 1

query II
SELECT count(*), sum(i) FROM batch
----
50
2500

query I
SELECT count(*) FROM batch WHERE i % 2 = 0
----
0
